# Copy to .env and fill in. .env is gitignored — never commit real keys.

# football-data.org v4 (free tier). Header: X-Auth-Token.
FOOTBALL_DATA_API_KEY=

# Database location (SQLite first; swap to a Postgres URL later).
DATABASE_URL=sqlite:///db/worldcup.sqlite

# Logging
LOG_LEVEL=INFO

# Polite scraping defaults
HTTP_USER_AGENT=worldcup-forecast/0.1 (research; contact: you@example.com)
HTTP_MIN_INTERVAL_SECONDS=6.0
